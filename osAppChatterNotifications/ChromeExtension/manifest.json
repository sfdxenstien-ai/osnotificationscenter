{
  "manifest_version": 3,
  "name": "Salesforce Chatter Notifications",
  "version": "1.0.0",
  "description": "Real-time Salesforce Chatter notifications via WebSocket",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "https://osnotificationscenter.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chatter Notifications"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
